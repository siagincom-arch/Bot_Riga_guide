# ============================================================
# Riga Guide Bot — Environment Variables
# Скопируй в .env и заполни реальными значениями
# cp .env.example .env
# ============================================================

# --- Секреты (обязательные) ---
TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=

# --- Административные ---
ADMIN_CHAT_ID=0

# --- Пути к данным ---
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/bot.db
LOG_PATH=./logs/bot.jsonl
LOG_LEVEL=INFO

# --- RAG параметры ---
RAG_TOP_K=6
RAG_GRADE_THRESHOLD=0.6
VISION_CONFIDENCE_THRESHOLD=0.5

# --- Session ---
SESSION_WINDOW=10
SESSION_TTL_HOURS=24

# --- Geo ---
NEARBY_RADIUS_M=300
